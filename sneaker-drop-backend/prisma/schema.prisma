// Sneaker Drop - Full Data Model
// Optimized for high-traffic concurrency with proper indexing

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  createdAt DateTime @default(now())

  purchases    Purchase[]
  reservations Reservation[]
}

model Drop {
  id             String   @id @default(uuid())
  name           String
  price          Int
  totalStock     Int
  availableStock Int
  startTime      DateTime
  imageUrl       String?
  description    String?
  brand          String?
  colorway       String?
  createdAt      DateTime @default(now())

  purchases    Purchase[]
  reservations Reservation[]

  @@index([startTime])
  @@index([availableStock])
}

model Reservation {
  id        String            @id @default(uuid())
  userId    String
  dropId    String
  expiresAt DateTime
  status    ReservationStatus @default(ACTIVE)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  drop Drop @relation(fields: [dropId], references: [id], onDelete: Cascade)

  @@index([dropId, status])
  @@index([expiresAt])
  @@index([userId, dropId, status])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  dropId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  drop Drop @relation(fields: [dropId], references: [id], onDelete: Cascade)

  @@index([dropId, createdAt])
  @@index([userId])
}

enum ReservationStatus {
  ACTIVE
  EXPIRED
  COMPLETED
}
